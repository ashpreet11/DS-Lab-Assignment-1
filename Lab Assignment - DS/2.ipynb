   "source": [
    "# Program to Search an Element in a List \n",
    "\n",
    "l = [10, 20, 30, 40, 50]\n",
    "print(\"List:\", l)\n",
    "\n",
    "element = int(input(\"Enter element to search: \"))\n",
    "\n",
    "if element in l:\n",
    "    print(\"Element found at index:\", l.index(element))\n",
    "else:\n",
    "    print(\"Element not found\")\n",
    "\n",
    "\n"
   ]
  }
 ],
