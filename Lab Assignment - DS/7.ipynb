   "source": [
    "def factorial(n):\n",
    "    \n",
    "    print(\"Function call: factorial(\",n,\")\")\n",
    "    if n == 0 or n == 1:\n",
    "        return 1\n",
    "\n",
    "    return n * factorial(n-1)\n",
    "\n",
    "print(factorial(4))        \n"
   ]
  }
